<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8" />
  <title>Curva ABC - BuyFlow</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <%- include('./partials/header') -%>

  <main class="bf-main">
    <div class="bf-page-header">
      <div>
        <h2>Curva ABC de Vendas</h2>
        <p class="bf-page-subtitle">
          Identifique os produtos que mais influenciam no faturamento.
        </p>
      </div>
    </div>

    <form method="GET" action="/vendas/curva-abc" class="bf-filtros">
      <div class="bf-filtro-group">
        <label for="periodo">Período</label>
        <select id="periodo" name="periodo">
          <option value="7d"  <%= periodo === "7d"  ? "selected" : "" %>>Últimos 7 dias</option>
          <option value="30d" <%= periodo === "30d" ? "selected" : "" %>>Últimos 30 dias</option>
          <option value="90d" <%= periodo === "90d" ? "selected" : "" %>>Últimos 90 dias</option>
          <option value="12m" <%= periodo === "12m" ? "selected" : "" %>>Últimos 12 meses</option>
        </select>
      </div>

      <div class="bf-filtro-actions">
        <button type="submit" class="bf-btn bf-btn-primary">Aplicar</button>
      </div>
    </form>

    <section class="bf-section">
      <div class="bf-section-header">
        <h3>Resumo</h3>
      </div>

      <ul class="bf-resumo-list">
        <li>Total de itens na curva: <strong><%= resumo.totalItens %></strong></li>
        <li>
          Classe A (% do faturamento):
          <strong><%= resumo.classeA_percentual.toFixed(2) %>%</strong>
        </li>
        <li>
          Classe B (% do faturamento):
          <strong><%= resumo.classeB_percentual.toFixed(2) %>%</strong>
        </li>
        <li>
          Classe C (% do faturamento):
          <strong><%= resumo.classeC_percentual.toFixed(2) %>%</strong>
        </li>
      </ul>
    </section>

    <section class="bf-section">
      <div class="bf-section-header">
        <h3>Itens por Classe</h3>
      </div>

      <% if (!itens || itens.length === 0) { %>
        <p class="bf-empty-state">
          Ainda não há dados para a Curva ABC neste período.
        </p>
      <% } else { %>
        <div class="bf-table-wrapper">
          <table class="bf-table">
            <thead>
              <tr>
                <th>Classe</th>
                <th>Código</th>
                <th>Produto</th>
                <th>Categoria</th>
                <th>Qtd Vendida</th>
                <th>Faturamento (R$)</th>
                <th>% do Faturamento</th>
                <th>% Acumulado</th>
              </tr>
            </thead>
            <tbody>
              <% itens.forEach(function(item) { %>
                <tr>
                  <td><%= item.classe %></td>
                  <td><%= item.codigo %></td>
                  <td><%= item.nomeProduto %></td>
                  <td><%= item.categoria %></td>
                  <td><%= Number(item.quantidade).toFixed(2) %></td>
                  <td>R$ <%= Number(item.faturamento).toFixed(2) %></td>
                  <td><%= Number(item.percentual).toFixed(2) %>%</td>
                  <td><%= Number(item.percentualAcumulado).toFixed(2) %>%</td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </section>
  </main>

  <%- include('./partials/footer') -%>
</body>
</html>