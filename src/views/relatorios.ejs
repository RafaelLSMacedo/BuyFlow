<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8" />
  <title>Relatórios - BuyFlow</title>
  <link rel="stylesheet" href="/css/styles.css" />
</head>
<body>
  <%- include('./partials/header') %>

  <main class="bf-main">
    <h2>Relatórios de Vendas</h2>

    <form method="GET" action="/relatorios" class="bf-filtros">
      <div>
        <label for="dataInicio">Data início:</label>
        <input type="date" id="dataInicio" name="dataInicio" value="<%= filtros.dataInicio || '' %>" />
      </div>

      <div>
        <label for="dataFim">Data fim:</label>
        <input type="date" id="dataFim" name="dataFim" value="<%= filtros.dataFim || '' %>" />
      </div>

      <div>
        <label for="canal">Canal:</label>
        <select id="canal" name="canal">
          <option value="todos" <%= filtros.canal === 'todos' ? 'selected' : '' %>>Todos</option>
          <option value="ecommerce" <%= filtros.canal === 'ecommerce' ? 'selected' : '' %>>E-commerce</option>
          <option value="loja_fisica" <%= filtros.canal === 'loja_fisica' ? 'selected' : '' %>>Loja física</option>
          <option value="marketplace" <%= filtros.canal === 'marketplace' ? 'selected' : '' %>>Marketplace</option>
        </select>
      </div>

      <button type="submit">Gerar</button>
    </form>

    <section>
      <h3>Resultados</h3>

      <% if (!resultados || resultados.length === 0) { %>
        <p>Ainda não há resultados para os filtros selecionados.</p>
      <% } else { %>
        <table class="bf-tabela">
          <thead>
            <tr>
              <th>Data</th>
              <th>Canal</th>
              <th>Qtd. Vendas</th>
              <th>Faturamento (R$)</th>
            </tr>
          </thead>
          <tbody>
            <% resultados.forEach(function(linha) { %>
              <tr>
                <td><%= linha.data %></td>
                <td><%= linha.canal %></td>
                <td><%= linha.quantidade %></td>
                <td><%= linha.faturamento.toFixed(2) %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </section>
  </main>

  <%- include('./partials/footer') %>
</body>
</html>